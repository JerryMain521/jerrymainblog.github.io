---
/**
 * BarrelShifter — 桶形移位器可视化交互组件
 *
 * 用法（在 .mdx 文件中）：
 *
 * import BarrelShifter from '@/components/circuits/BarrelShifter.astro'
 *
 * <BarrelShifter />
 *
 * 可选 Props：
 *   defaultBits   - 初始8位输入，默认 [1,0,1,1,0,1,0,0]
 *   defaultShift  - 初始移位量（1-4），默认 2
 *   defaultMode   - 初始模式 'logical' | 'arithmetic' | 'rotate'，默认 'logical'
 */

interface Props {
  defaultBits?: number[]
  defaultShift?: number
  defaultMode?: 'logical' | 'arithmetic' | 'rotate'
}

const {
  defaultBits = [1, 0, 1, 1, 0, 1, 0, 0],
  defaultShift = 2,
  defaultMode = 'logical',
} = Astro.props

const id = `bs-${Math.random().toString(36).slice(2, 7)}`
---

<div class={`barrel-shifter not-prose`} id={id}>
  <div class='bs-controls'>
    <div class='bs-ctrl-group'>
      <div class='bs-ctrl-label'>输入（点击切换）</div>
      <div class='bs-bit-row' data-role='input-bits'></div>
    </div>
    <div class='bs-divider'></div>
    <div class='bs-ctrl-group'>
      <div class='bs-ctrl-label'>移位量</div>
      <div class='bs-shift-row' data-role='shift-btns'></div>
    </div>
    <div class='bs-divider'></div>
    <div class='bs-ctrl-group'>
      <div class='bs-ctrl-label'>模式</div>
      <div class='bs-mode-row' data-role='mode-btns'></div>
    </div>
  </div>

  <div class='bs-viz'>
    <div class='bs-row' data-role='row-input' style='display:flex;align-items:center;padding:8px 16px;border-bottom:0.5px solid hsl(var(--border)/0.4);'></div>
    <div data-role='arrow-row' style='display:flex;flex-direction:row;padding:2px 16px 2px calc(16px + 62px);gap:5px;'></div>
    <div class='bs-row' data-role='row-output' style='display:flex;align-items:center;padding:8px 16px;'></div>
    <div data-role='info-bar' style='display:flex;flex-wrap:wrap;gap:16px;padding:8px 16px;border-top:0.5px solid hsl(var(--border)/0.4);font-size:11px;font-family:monospace;color:hsl(var(--muted-foreground));background:hsl(var(--muted)/0.4);'></div>
  </div>
</div>

<style>
  .barrel-shifter {
    margin: 1.5rem 0;
    font-family: var(--font-sans, sans-serif);
  }

  .bs-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-bottom: 1rem;
  }

  .bs-ctrl-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .bs-ctrl-label {
    font-size: 0.7rem;
    color: hsl(var(--muted-foreground));
  }

  .bs-divider {
    width: 1px;
    background: hsl(var(--border) / 0.4);
    align-self: stretch;
  }

  .bs-bit-row,
  .bs-shift-row,
  .bs-mode-row {
    display: flex;
    gap: 5px;
  }

  .bs-bit-btn {
    width: 36px;
    height: 36px;
    border-radius: 0.5rem;
    border: 0.5px solid hsl(var(--border));
    background: transparent;
    color: hsl(var(--foreground));
    font-family: var(--font-mono, monospace);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }

  .bs-bit-btn.on {
    background: hsl(210 80% 95%);
    color: hsl(213 80% 27%);
    border-color: hsl(213 60% 72%);
  }

  .bs-shift-btn,
  .bs-mode-btn {
    padding: 4px 10px;
    height: 28px;
    border-radius: 0.5rem;
    border: 0.5px solid hsl(var(--border));
    background: transparent;
    color: hsl(var(--muted-foreground));
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.12s;
  }

  .bs-shift-btn.active,
  .bs-mode-btn.active {
    background: hsl(var(--muted));
    color: hsl(var(--foreground));
    border-color: hsl(var(--border));
  }

  .bs-viz {
    border: 0.5px solid hsl(var(--border) / 0.5);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .bs-row {
    display: flex;
    align-items: center;
    padding: 8px 16px;
    border-bottom: 0.5px solid hsl(var(--border) / 0.4);
  }

  .bs-arrow-row {
    display: flex;
    padding: 2px 16px 2px calc(16px + 62px);
    gap: 5px;
  }

  .bs-row-label {
    font-size: 0.7rem;
    color: hsl(var(--muted-foreground));
    font-family: var(--font-mono, monospace);
    min-width: 56px;
    text-align: right;
    padding-right: 10px;
    line-height: 38px;
  }

  .bs-cells {
    display: flex;
    gap: 5px;
    flex: 1;
  }

  .bs-cell {
    width: 38px;
    height: 38px;
    border-radius: 0.5rem;
    border: 0.5px solid hsl(var(--border) / 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono, monospace);
    font-size: 16px;
    font-weight: 500;
    transition: background 0.2s, color 0.2s;
    color: hsl(var(--muted-foreground));
  }

  .bs-cell.v1 {
    background: hsl(210 80% 95%);
    color: hsl(213 80% 27%);
    border-color: hsl(213 60% 72%);
  }

  .bs-cell.moved {
    background: hsl(100 50% 92%);
    color: hsl(100 55% 24%);
    border-color: hsl(100 45% 56%);
  }

  .bs-cell.vacated {
    background: transparent;
    color: hsl(var(--muted-foreground) / 0.4);
  }

  .bs-cell.msb {
    background: hsl(0 70% 97%);
    color: hsl(0 60% 35%);
    border-color: hsl(0 60% 72%);
  }

  .bs-arrow-cell {
    width: 38px;
    height: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: hsl(var(--muted-foreground));
  }

  .bs-hex {
    font-size: 0.7rem;
    color: hsl(var(--muted-foreground));
    font-family: var(--font-mono, monospace);
    min-width: 40px;
    padding-left: 10px;
    line-height: 38px;
  }

  .bs-info {
    display: flex;
    gap: 16px;
    padding: 8px 16px;
    background: hsl(var(--muted) / 0.4);
    border-top: 0.5px solid hsl(var(--border) / 0.4);
    font-size: 0.7rem;
    color: hsl(var(--muted-foreground));
    font-family: var(--font-mono, monospace);
    flex-wrap: wrap;
  }

  .bs-info strong {
    color: hsl(var(--foreground));
    font-weight: 500;
  }
</style>

<script define:vars={{ id, defaultBits, defaultShift, defaultMode }}>
  ;(function () {
    const root = document.getElementById(id)
    if (!root) return

    let bits = [...defaultBits]
    let shift = defaultShift
    let mode = defaultMode

    const modes = [
      { key: 'logical', label: '逻辑左移' },
      { key: 'arithmetic', label: '算术右移' },
      { key: 'rotate', label: '循环右移' },
    ]

    function compute(bits, shift, mode) {
      const n = bits.length
      let out = Array(n).fill(0)
      let flags = Array(n).fill('normal')

      if (mode === 'logical') {
        for (let i = 0; i < n; i++) {
          if (i + shift < n) out[i] = bits[i + shift]
        }
        for (let i = n - shift; i < n; i++) flags[i] = 'vacated'
        for (let i = 0; i < n - shift; i++) flags[i] = 'moved'
      } else if (mode === 'arithmetic') {
        const sign = bits[0]
        for (let i = 0; i < n; i++) {
          out[i] = i - shift >= 0 ? bits[i - shift] : sign
        }
        for (let i = 0; i < shift; i++) flags[i] = 'msb'
        for (let i = shift; i < n; i++) flags[i] = 'moved'
      } else {
        for (let i = 0; i < n; i++) {
          out[i] = bits[(i + shift) % n]
          flags[i] = 'moved'
        }
      }
      return { out, flags }
    }

    function toHex(bits) {
      const val = bits.reduce((a, b, i) => a | (b << (bits.length - 1 - i)), 0)
      return '0x' + (val >>> 0).toString(16).toUpperCase().padStart(2, '0')
    }

    const S = {
      row: 'display:flex;align-items:center;',
      cells: 'display:flex;flex-direction:row;flex-wrap:nowrap;gap:5px;flex:1;',
      cell: (bg, color, border) =>
        `display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;` +
        `border-radius:6px;border:0.5px solid ${border};background:${bg};color:${color};` +
        `font-family:monospace;font-size:15px;font-weight:500;flex-shrink:0;box-sizing:border-box;`,
      label: 'font-size:11px;color:hsl(var(--muted-foreground));font-family:monospace;min-width:52px;text-align:right;padding-right:10px;white-space:nowrap;',
      hex: 'font-size:11px;color:hsl(var(--muted-foreground));font-family:monospace;min-width:44px;padding-left:10px;white-space:nowrap;',
      arrowRow: 'display:flex;flex-direction:row;padding:2px 16px 2px calc(16px + 62px);gap:5px;',
      arrowCell: 'display:inline-flex;align-items:center;justify-content:center;width:36px;height:14px;font-size:11px;color:hsl(var(--muted-foreground));flex-shrink:0;',
      bitBtn: (on) =>
        `display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;` +
        `border-radius:6px;cursor:pointer;font-family:monospace;font-size:15px;font-weight:500;` +
        `border:0.5px solid ${on ? 'hsl(213 60% 72%)' : 'hsl(var(--border))'};` +
        `background:${on ? 'hsl(210 80% 95%)' : 'transparent'};` +
        `color:${on ? 'hsl(213 80% 27%)' : 'hsl(var(--foreground))'};`,
      smallBtn: (active) =>
        `display:inline-flex;align-items:center;justify-content:center;padding:4px 10px;height:28px;` +
        `border-radius:6px;cursor:pointer;font-size:12px;font-weight:500;` +
        `border:0.5px solid hsl(var(--border));` +
        `background:${active ? 'hsl(var(--muted))' : 'transparent'};` +
        `color:${active ? 'hsl(var(--foreground))' : 'hsl(var(--muted-foreground))'};`,
    }

    function cellStyle(b, flag) {
      if (flag === 'vacated') return S.cell('transparent', 'hsl(var(--muted-foreground)/0.3)', 'hsl(var(--border)/0.3)')
      if (flag === 'msb')     return S.cell('hsl(0 70% 97%)', 'hsl(0 60% 35%)', 'hsl(0 60% 72%)')
      if (flag === 'moved' && b === 1) return S.cell('hsl(100 50% 92%)', 'hsl(100 55% 24%)', 'hsl(100 45% 56%)')
      if (b === 1) return S.cell('hsl(210 80% 95%)', 'hsl(213 80% 27%)', 'hsl(213 60% 72%)')
      return S.cell('transparent', 'hsl(var(--muted-foreground))', 'hsl(var(--border)/0.4)')
    }

    function render() {
      const { out, flags } = compute(bits, shift, mode)

      // Input bit toggle buttons
      root.querySelector('[data-role="input-bits"]').innerHTML = bits
        .map((b, i) => `<button style="${S.bitBtn(b)}" data-bit="${i}">${b}</button>`)
        .join('')

      // Shift buttons
      root.querySelector('[data-role="shift-btns"]').innerHTML = [1, 2, 3, 4]
        .map((s) => `<button style="${S.smallBtn(shift === s)}" data-shift="${s}">${s}</button>`)
        .join('')

      // Mode buttons
      root.querySelector('[data-role="mode-btns"]').innerHTML = modes
        .map((m) => `<button style="${S.smallBtn(mode === m.key)}" data-mode="${m.key}">${m.label}</button>`)
        .join('')

      // Input row
      root.querySelector('[data-role="row-input"]').innerHTML =
        `<span style="${S.label}">输入</span>` +
        `<span style="${S.cells}">${bits.map((b) => `<span style="${cellStyle(b, 'normal')}">${b}</span>`).join('')}</span>` +
        `<span style="${S.hex}">${toHex(bits)}</span>`

      // Arrow row
      root.querySelector('[data-role="arrow-row"]').style.cssText = S.arrowRow
      root.querySelector('[data-role="arrow-row"]').innerHTML = bits
        .map((_, i) => {
          let arrow = ''
          if (mode === 'logical') arrow = i < bits.length - shift ? '↑' : ''
          else if (mode === 'arithmetic') arrow = i >= shift ? '↑' : '↓'
          else arrow = '↻'
          return `<span style="${S.arrowCell}">${arrow}</span>`
        })
        .join('')

      // Output row
      root.querySelector('[data-role="row-output"]').innerHTML =
        `<span style="${S.label}">输出</span>` +
        `<span style="${S.cells}">${out.map((b, i) => `<span style="${cellStyle(b, flags[i])}">${b}</span>`).join('')}</span>` +
        `<span style="${S.hex}">${toHex(out)}</span>`

      // Info bar
      const modeLabel = modes.find((m) => m.key === mode)?.label || ''
      root.querySelector('[data-role="info-bar"]').innerHTML =
        `<span>输入 <strong>${toHex(bits)}</strong></span>` +
        `<span>移位量 <strong>${shift}</strong></span>` +
        `<span>模式 <strong>${modeLabel}</strong></span>` +
        `<span>输出 <strong>${toHex(out)}</strong></span>`
    }

    // Event delegation
    root.addEventListener('click', (e) => {
      const btn = e.target.closest('button')
      if (!btn) return
      if (btn.dataset.bit !== undefined) {
        const i = +btn.dataset.bit
        bits[i] = bits[i] ? 0 : 1
        render()
      } else if (btn.dataset.shift !== undefined) {
        shift = +btn.dataset.shift
        render()
      } else if (btn.dataset.mode !== undefined) {
        mode = btn.dataset.mode
        render()
      }
    })

    render()
  })()
</script>