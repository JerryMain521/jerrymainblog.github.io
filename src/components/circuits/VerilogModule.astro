---
/**
 * VerilogModule — 带行注释高亮的 Verilog 代码展示组件
 *
 * 用法：
 * <VerilogModule
 *   code={`module adder(...); ... endmodule`}
 *   annotations={[
 *     { line: 2, label: "端口定义", desc: "列出模块所有端口" },
 *   ]}
 * />
 *
 * Props:
 *   code        - Verilog 代码字符串
 *   annotations - 行注释数组 { line: number, label: string, desc: string }
 */

interface Annotation {
  line: number
  label: string
  desc: string
}

interface Props {
  code: string
  annotations?: Annotation[]
}

const { code, annotations = [] } = Astro.props

const lines = code.split('\n')
const id = `vm-${Math.random().toString(36).slice(2, 7)}`

// Build a map from line number to annotations
const lineAnnoMap: Record<number, Annotation[]> = {}
for (const a of annotations) {
  if (!lineAnnoMap[a.line]) lineAnnoMap[a.line] = []
  lineAnnoMap[a.line].push(a)
}
---

<div class="vm-wrapper not-prose" id={id}>
  <div class="vm-header">
    <span class="vm-lang">Verilog HDL</span>
  </div>
  <div class="vm-body">
    <div class="vm-code">
      {lines.map((line, i) => {
        const lineNum = i + 1
        const annos = lineAnnoMap[lineNum] || []
        return (
          <div class={`vm-line ${annos.length ? 'vm-line-hl' : ''}`} data-line={lineNum}>
            <span class="vm-ln">{lineNum}</span>
            <span class="vm-text">{line || '\u00a0'}</span>
            {annos.length > 0 && (
              <span class="vm-anno-pill">
                {annos.map(a => <span class="vm-pill">{a.label}</span>)}
              </span>
            )}
          </div>
        )
      })}
    </div>
    {annotations.length > 0 && (
      <div class="vm-annotations">
        {annotations.map(a => (
          <div class="vm-anno-item">
            <span class="vm-anno-label">{a.label}</span>
            <span class="vm-anno-desc">{a.desc}</span>
          </div>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .vm-wrapper {
    margin: 1.5rem 0;
    border: 0.5px solid hsl(var(--border) / 0.5);
    border-radius: 0.75rem;
    overflow: hidden;
    font-family: var(--font-mono, monospace);
  }

  .vm-header {
    display: flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background: hsl(var(--muted) / 0.4);
    border-bottom: 0.5px solid hsl(var(--border) / 0.4);
  }

  .vm-lang {
    font-size: 0.7rem;
    color: hsl(var(--muted-foreground));
    font-family: var(--font-sans, sans-serif);
    letter-spacing: 0.06em;
  }

  .vm-body {
    display: flex;
    flex-direction: column;
  }

  .vm-code {
    overflow-x: auto;
    padding: 0.75rem 0;
  }

  .vm-line {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.15rem 1rem;
    transition: background 0.12s;
    min-height: 1.6rem;
  }

  .vm-line:hover {
    background: hsl(var(--muted) / 0.3);
  }

  .vm-line-hl {
    background: hsl(var(--primary) / 0.05);
    border-left: 2px solid hsl(var(--primary) / 0.4);
  }

  .vm-line-hl:hover {
    background: hsl(var(--primary) / 0.08);
  }

  .vm-ln {
    min-width: 1.8rem;
    text-align: right;
    font-size: 0.72rem;
    color: hsl(var(--muted-foreground) / 0.5);
    user-select: none;
    flex-shrink: 0;
  }

  .vm-text {
    font-size: 0.83rem;
    color: hsl(var(--foreground));
    white-space: pre;
    flex: 1;
    line-height: 1.6;
  }

  .vm-anno-pill {
    display: flex;
    gap: 0.3rem;
    flex-shrink: 0;
  }

  .vm-pill {
    font-size: 0.62rem;
    font-family: var(--font-sans, sans-serif);
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    background: hsl(var(--primary) / 0.12);
    color: hsl(var(--primary));
    white-space: nowrap;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .vm-annotations {
    border-top: 0.5px solid hsl(var(--border) / 0.4);
    background: hsl(var(--muted) / 0.2);
    padding: 0.6rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .vm-anno-item {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 0.78rem;
  }

  .vm-anno-label {
    font-family: var(--font-sans, sans-serif);
    font-weight: 500;
    color: hsl(var(--primary));
    min-width: 5rem;
    font-size: 0.72rem;
    flex-shrink: 0;
  }

  .vm-anno-desc {
    color: hsl(var(--muted-foreground));
    font-family: var(--font-sans, sans-serif);
    font-size: 0.75rem;
  }
</style>