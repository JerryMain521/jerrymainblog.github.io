---
/**
 * OperatorPriority — Verilog HDL 运算符优先级可视化表
 */
const id = `op-${Math.random().toString(36).slice(2, 7)}`

const groups = [
  { priority: 1, label: '最高', category: '逻辑 / 位', ops: ['!', '~'], color: 'red' },
  { priority: 2, label: '',     category: '算术',       ops: ['*', '/', '%'], color: 'orange' },
  { priority: 3, label: '',     category: '算术',       ops: ['+', '-'], color: 'orange' },
  { priority: 4, label: '',     category: '移位',       ops: ['<<', '>>'], color: 'yellow' },
  { priority: 5, label: '',     category: '关系',       ops: ['<', '<=', '>', '>='], color: 'green' },
  { priority: 6, label: '',     category: '等式',       ops: ['==', '!=', '===', '!=='], color: 'teal' },
  { priority: 7, label: '',     category: '缩减 / 位',  ops: ['&', '~&'], color: 'blue' },
  { priority: 8, label: '',     category: '缩减 / 位',  ops: ['^', '^~'], color: 'blue' },
  { priority: 9, label: '',     category: '缩减 / 位',  ops: ['|', '~|'], color: 'blue' },
  { priority: 10, label: '',    category: '逻辑',       ops: ['&&'], color: 'purple' },
  { priority: 11, label: '',    category: '逻辑',       ops: ['||'], color: 'purple' },
  { priority: 12, label: '最低', category: '条件',      ops: ['? :'], color: 'pink' },
]

const colorMap: Record<string, string> = {
  red:    'hsl(0 70% 50%)',
  orange: 'hsl(25 80% 50%)',
  yellow: 'hsl(45 80% 45%)',
  green:  'hsl(140 55% 38%)',
  teal:   'hsl(170 55% 38%)',
  blue:   'hsl(210 70% 48%)',
  purple: 'hsl(265 60% 50%)',
  pink:   'hsl(320 55% 45%)',
}
---

<div class="op-wrapper not-prose" id={id}>
  <div class="op-header">
    <span class="op-title">运算符优先级</span>
    <span class="op-subtitle">从高到低</span>
  </div>
  <div class="op-table">
    <div class="op-col-label">优先级</div>
    <div class="op-col-cat">类别</div>
    <div class="op-col-ops">运算符</div>
    <div class="op-col-note">说明</div>
    {groups.map((g, idx) => (
      <>
        <div class="op-row-priority">
          <span class="op-badge" style={`color: ${colorMap[g.color]}`}>{g.priority}</span>
          {g.label && <span class="op-extremity">{g.label}</span>}
        </div>
        <div class="op-row-cat" style={`color: ${colorMap[g.color]}`}>{g.category}</div>
        <div class="op-row-ops">
          {g.ops.map(op => (
            <code class="op-code" style={`border-color: ${colorMap[g.color]}30; color: ${colorMap[g.color]}`}>{op}</code>
          ))}
        </div>
        <div class="op-row-note">
          {g.priority === 1 && '单目运算符，优先级最高'}
          {g.priority === 2 && '乘、除、求模'}
          {g.priority === 3 && '加、减'}
          {g.priority === 4 && '左移、右移'}
          {g.priority === 5 && '所有关系运算符同级'}
          {g.priority === 6 && '=== 和 !==（case等式）Quartus不支持'}
          {g.priority === 7 && '按位/缩减与、与非'}
          {g.priority === 8 && '按位/缩减异或、同或'}
          {g.priority === 9 && '按位/缩减或、或非'}
          {g.priority === 10 && '逻辑与'}
          {g.priority === 11 && '逻辑或'}
          {g.priority === 12 && '三目，优先级最低'}
        </div>
      </>
    ))}
  </div>
  <div class="op-tip">
    💡 建议使用括号明确优先级，如 <code>(a &gt; b) &amp;&amp; (b &gt; c)</code>
  </div>
</div>

<style>
  .op-wrapper {
    margin: 1.5rem 0;
    border: 0.5px solid hsl(var(--border) / 0.5);
    border-radius: 0.75rem;
    overflow: hidden;
    font-family: var(--font-sans, sans-serif);
  }

  .op-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: hsl(var(--muted) / 0.4);
    border-bottom: 0.5px solid hsl(var(--border) / 0.4);
  }

  .op-title {
    font-size: 0.8rem;
    font-weight: 500;
    color: hsl(var(--foreground));
  }

  .op-subtitle {
    font-size: 0.72rem;
    color: hsl(var(--muted-foreground));
    margin-left: auto;
  }

  .op-table {
    display: grid;
    grid-template-columns: 4.5rem 6rem 1fr 1fr;
    font-size: 0.8rem;
  }

  /* Column headers */
  .op-col-label, .op-col-cat, .op-col-ops, .op-col-note {
    padding: 0.35rem 0.75rem;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: hsl(var(--muted-foreground));
    border-bottom: 0.5px solid hsl(var(--border) / 0.4);
    background: hsl(var(--muted) / 0.2);
  }

  /* Data rows - each group spans 4 cols via grid placement */
  .op-row-priority, .op-row-cat, .op-row-ops, .op-row-note {
    display: flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    border-bottom: 0.5px solid hsl(var(--border) / 0.2);
    min-height: 2.2rem;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .op-row-priority {
    justify-content: center;
    flex-direction: column;
    align-items: center;
  }

  .op-badge {
    font-family: var(--font-mono, monospace);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .op-extremity {
    font-size: 0.6rem;
    color: hsl(var(--muted-foreground));
    white-space: nowrap;
  }

  .op-row-cat {
    font-weight: 500;
    font-size: 0.75rem;
  }

  .op-row-ops {
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .op-code {
    font-family: var(--font-mono, monospace);
    font-size: 0.78rem;
    padding: 0.1rem 0.4rem;
    border-radius: 0.3rem;
    border: 0.5px solid;
    background: transparent;
    font-weight: 500;
  }

  .op-row-note {
    font-size: 0.72rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.4;
  }

  .op-tip {
    padding: 0.6rem 1rem;
    font-size: 0.75rem;
    color: hsl(var(--muted-foreground));
    background: hsl(var(--muted) / 0.3);
    border-top: 0.5px solid hsl(var(--border) / 0.4);
  }

  .op-tip code {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: hsl(var(--foreground));
  }
</style>