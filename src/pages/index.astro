---
import BaseLayout from "../layouts/BaseLayout.astro"

const base = import.meta.env.BASE_URL || "";
---

<BaseLayout pageTitle="JerryMain's Site">
    <div class="space-y-6">
        <p class="text-xl leading-relaxed" style="color: var(--color-muted);">
            Welcome to my corner of the internet. I write about technology, programming, and things I find interesting.
        </p>
        <div class="flex gap-4 pt-2">
            <a href={`${base}/blog`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium text-white transition-opacity hover:opacity-90" style="background-color: var(--color-accent);">
                Read Blog
            </a>
            <a href={`${base}/about`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium border transition-opacity hover:opacity-80" style="border-color: var(--color-border); color: var(--color-text);">
                About Me
            </a>
        </div>
    </div>
</BaseLayout>
