---
import { getCollection, type CollectionEntry } from 'astro:content'
import { cn } from 'astro-pure/utils'

export const prerender = true
export const partial = true

const tutorialsCollection = (await getCollection('tutorials')) as CollectionEntry<'tutorials'>[]

// Group by first two path segments (e.g. basics, combinational, sequential)
const tutorialsByCate = tutorialsCollection.reduce(
  (acc: { [key: string]: typeof tutorialsCollection }, doc) => {
    const parts = doc.id.split('/')
    const id = parts.length >= 2 ? parts[0] : parts[0]
    if (!acc[id]) acc[id] = [] as typeof tutorialsCollection
    acc[id].push(doc)
    return acc
  },
  {}
)

// 在这里维护分类顺序和名称
const tutorialCategories: Record<string, string> = {
  basics: '基础知识',
  combinational: '组合逻辑',
  sequential: '时序逻辑',
  verilog: 'VerilogHDL',
}

type Props = {
  title?: boolean
  class?: string
}

const { title = true, class: className, ...props } = Astro.props
---

<tutorial-toc class={cn('not-prose', className)} {...props}>
  {title && <h2 class='text-foreground font-medium'>TUTORIALS</h2>}
  <ul class='mt-4 flex flex-col gap-y-5'>
    {
      Object.entries(tutorialCategories).map(([id, catTitle]) => (
        <li>
          <h3 class='text-muted-foreground text-xs tracking-widest uppercase'>{catTitle}</h3>
          <ul class='mt-2 flex flex-col'>
            {(tutorialsByCate[id] ?? [])
              .sort((a, b) => a.data.order - b.data.order)
              .map((doc) => (
                <li class='tutorial-item flex relative ms-2 px-3 py-1 text-foreground/75 transition-all rounded-2xl'>
                  <a class='flex-1 hover:text-foreground' href={`/tutorials/${doc.id}`}>
                    {doc.data.title}
                  </a>
                </li>
              ))}
          </ul>
        </li>
      ))
    }
  </ul>
</tutorial-toc>

<style>
  tutorial-toc .tutorial-item::before {
    content: '';
    display: block;
    position: absolute;
    top: 5%;
    bottom: 5%;
    left: -0.5rem;
    width: 2px;
    background-color: hsl(var(--input) / var(--un-bg-opacity));
  }

  tutorial-toc :global(.tutorial-item.tutorial-hl) {
    background-color: hsl(var(--muted) / var(--un-bg-opacity));
    font-weight: 500;
    & a {
      color: hsl(var(--primary) / var(--un-text-opacity));
    }
    &::before {
      background-color: hsl(var(--primary) / var(--un-bg-opacity));
    }
  }
</style>

<script>
  class TutorialTOC extends HTMLElement {
    link: string = ''

    constructor() {
      super()
      this.link = window.location.pathname
    }

    connectedCallback() {
      const links = this.querySelectorAll('a')
      links.forEach((link) => {
        if (link.getAttribute('href') === this.link) {
          link.parentElement?.classList.add('tutorial-hl')
        }
      })
    }
  }

  customElements.define('tutorial-toc', TutorialTOC)
</script>